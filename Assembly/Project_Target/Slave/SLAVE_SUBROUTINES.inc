	    GOTO	$-1			;TMR1 NOT DONE
	    BANKSEL	T1CON
	    BCF		T1CON,0			;DISABLE TIMER 1
	    RETURN

	    
;SEND COLORS OUT TO THE WS2812B LEDS
SENDLED:
    BANKSEL _LEDNUMBER
    MOVF _LEDNUMBER, W
    MOVWF _LEDCOUNTER

