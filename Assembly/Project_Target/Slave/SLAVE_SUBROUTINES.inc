SUBROUTINES_CODE CODE
 
 ;Writes to EEPROM
	;**** Do not under any circumstances ****
	;**** Use EEPROM row 0 it is evil ****
Write_EEPROM:
	    BANKSEL	PORTA
	    MOVFW	EEPROM_ADDR
	    BANKSEL	EEADRL
	    MOVWF	EEADRL
	    BANKSEL	PORTA
	    MOVFW	EEPROM_DATA
	    BANKSEL	EEDATL
	    MOVWF	EEDATL
	    BCF		EECON1,6
	    BCF		EECON1,7
	    BSF		EECON1,2

	    BCF		INTCON,GIE
	    MOVLW	0x55
	    MOVWF	EECON2
	    MOVLW	0xAA
	    MOVWF	EECON2
	    BSF		EECON1,WR
    Loop:   BSF		INTCON,GIE
	    BCF		EECON1,WREN
	    BTFSC	EECON1,WR
	    GOTO	Loop
	    RETURN

	;Reads from EEPROM
	;**** Do not under any circumstances ****
	;**** Use EEPROM row 0 it is evil ****
Read_EEPROM:
	    BANKSEL	PORTA
	    MOVFW	EEPROM_ADDR
	    BANKSEL	EEADRL
	    MOVWF	EEADRL
	    BANKSEL	EECON1
	    BCF		EECON1,6
	    BCF		EECON1,7
	    BSF		EECON1,0
	    MOVF	EEDATL,0
	    BANKSEL	PORTA
	    MOVWF	EEPROM_SAVE
	    RETURN
    
    ;RECEIVES AND INTERPRETS I2C DATA, RESPONDS TO I2C READ REQUESTS
    RECEIVE: 
	    BANKSEL	PIR1
	    BCF		PIR1, SSP1IF		;IMMEDIATELY CLEAR INTERRUPT FLAG
	    BANKSEL	SSP1BUF			;\READ BYTE FROM MASTER
	    MOVFW	SSP1BUF			;/
	    MOVWF	RECEIVED_DATA
	    BANKSEL	SSP1STAT		;DETERMINE IF THE RECEIVED BYTE WAS DATA OR ADDRESS
	    BTFSS	SSP1STAT,5		;1=DATA, 0=ADDRESS
	    GOTO	CHECK_READ_OR_WRITE	;BYTE RECEIVED WAS ADDRESS, CHECK IF R/W
	    GOTO	SAVE_DATA		;BYTE RECEIVED WAS DATA, SAVE BYTE
	    
	CHECK_READ_OR_WRITE	
	    BTFSS	SSP1STAT,2		;TEST IF ADDRESS BYTE WAS R/W: R = 1, W = 0
	    GOTO	SAVE_DATA		;MASTER WRITE: SAVE DATA
	    GOTO	TRANSMIT_STATUS		;MASTER READ: TRANSMIT THE TARGET STATUS
	
	;TESTS THE RECEIVED DATA AGAINST THE KNOWN ENABLE AND DISABLE COMMANDS
	SAVE_DATA
	    BANKSEL	PORTA
	    MOVWF	RECEIVED_DATA
	    XORLW	0X45
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS ENABLE COMMAND, SET TARGET TO ACTIVE
	    GOTO	ENABLE_TARGET	    
	    MOVFW	RECEIVED_DATA
	    XORLW	0X44
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS DISABLE COMMAND, SET TARGET TO INACTIVE
	    GOTO	DISABLE_TARGET
	    MOVFW	RECEIVED_DATA
	    XORLW	0X43
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS CHANGE COLOR, SET TARGET TO INACTIVE
	    GOTO	CHANGE_COLOR
	    RETURN
	    
	UART_RX
	    BANKSEL	RCREG
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	EU_RX
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    BANKSEL	PORTA
	    MOVFW	EU_RX
	    
	    XORLW	0X24
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS VB HANDSHAKE, GOTO VB RECEIVE
	    GOTO	VB_RECEIVE
	    BANKSEL	PORTA
	    MOVFW	EU_RX
	    XORLW	0X3C
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS BLASTER HANDSHAKE, GOTO BLASTER RECEIVE
	    GOTO	BLASTER_RECEIVE
	
	    RETURN
	    
	VB_RECEIVE
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    BANKSEL	RCREG		    ;RETRIEVE THE RECEIVED BYTE
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	EU_RX		    ;STORE THE RECEIVED BYTE IN EU_RX
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    XORLW	0x56
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS DEVICE VERIFICATION, GOTO DEVICE_VERIFICATION
	    GOTO	DEVICE_VERIFICATION
	    
	    MOVFW	EU_RX
	    XORLW	0x53
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS READ SETTINGS, GOTO READ_SETTINGS
	    GOTO	READ_SETTINGS
	    
	    MOVFW	EU_RX
	    XORLW	0x43
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS COLOR CHANGE, GOTO EU_COLOR_CHANGE
	    GOTO	EU_COLOR_CHANGE
	    
	    MOVFW	EU_RX
	    XORLW	0x50
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS CALIBRATE POSITIONS, GOTO CHANGE_POSITIONS
	    GOTO	CHANGE_POSITIONS
	    
	    MOVFW	EU_RX
	    XORLW	0x4C
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS UPDATE LEDS, GOTO UPDATE_LED_NUMBER
	    GOTO	UPDATE_LED_NUMBER
	    
	    MOVFW	EU_RX
	    XORLW	0x41
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS UPDATE ADDRESS, GOTO UPDATE_ADDRESS
	    GOTO	UPDATE_ADDRESS
	    
	;SEND UNABLE RESPONSE ($U)
	SEND_UNABLE
	    BANKSEL	    TXSTA
	    BTFSS	    TXSTA, TRMT
	    GOTO	    $-1
	    BANKSEL	    TX1REG
	    MOVLW	    0x24 ;SENDS THE DOLLAR HANDSHAKE
	    MOVWF	    TX1REG
	    
	    BANKSEL	    TXSTA
	    BTFSS	    TXSTA, TRMT
	    GOTO	    $-1
	    BANKSEL	    TX1REG
	    MOVLW	    0x55 ;SENDS THE U
	    MOVWF	    TX1REG
	    
	    RETURN
	    
	BLASTER_RECEIVE
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    
	    BANKSEL	RCREG
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	PLAYER_HIT
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    
	    BANKSEL	RCREG
	    MOVFW	RCREG
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    BANKSEL	PORTA
	    XORLW	0x3E
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS BLASTER HANDSHAKE, GOTO HIT_RECORDED
	    GOTO	HIT_RECORDED
	    CLRF	PLAYER_HIT
	    	    
	    RETURN
	    
	HIT_RECORDED
	    CALL	DISABLE_TARGET	    ;DISABLE THE TARGET
	    
	    BANKSEL	PORTA
	    MOVFW	PLAYER_HIT
	    XORLW	0X01
	    BTFSC	STATUS, Z	    ;IF PLAYER ONE HIT THE TARGET, FLASH PLAYER ONE COLORS
	    GOTO	RECORD_PLAYER1_HIT
	    
	    MOVFW	PLAYER_HIT
	    XORLW	0X02
	    BTFSC	STATUS, Z	    ;IF PLAYER TWO HIT THE TARGET, FLASH PLAYER TWO COLORS
	    GOTO	RECORD_PLAYER2_HIT
	    
	    MOVFW	PLAYER_HIT
	    XORLW	0X03
	    BTFSC	STATUS, Z	    ;IF PLAYER THREE HIT THE TARGET, FLASH PLAYER THREE COLORS
	    GOTO	RECORD_PLAYER3_HIT
	    
	    MOVFW	PLAYER_HIT
	    XORLW	0X04
	    BTFSC	STATUS, Z	    ;IF PLAYER FOUR HIT THE TARGET, FLASH PLAYER FOUR COLORS
	    GOTO	RECORD_PLAYER4_HIT
	    
	    RETURN
	    
	;DEVICE VERIFICATION COMMAND RECEIVED, SEND $LAS
	DEVICE_VERIFICATION
	    BANKSEL	    TXSTA
	    BTFSS	    TXSTA, TRMT
	    GOTO	    $-1
	    BANKSEL	    TX1REG
	    MOVLW	    0x24 ;SENDS THE DOLLAR HANDSHAKE
	    MOVWF	    TX1REG
	    
	    BANKSEL	    TXSTA
	    BTFSS	    TXSTA, TRMT
	    GOTO	    $-1
	    BANKSEL	    TX1REG
	    MOVLW	    0x4C ;SENDS THE L
	    MOVWF	    TX1REG
	    
	    BANKSEL	    TXSTA
	    BTFSS	    TXSTA, TRMT
	    GOTO	    $-1
	    BANKSEL	    TX1REG
	    MOVLW	    0x41 ;SENDS THE A
	    MOVWF	    TX1REG
	    
	    BANKSEL	    TXSTA
	    BTFSS	    TXSTA, TRMT
	    GOTO	    $-1
	    BANKSEL	    TX1REG
	    MOVLW	    0x53 ;SENDS THE S
	    MOVWF	    TX1REG
	    
	    RETURN
	    
	;READ SETTINGS COMMAND, SEND ALL EEPROM DATA
	READ_SETTINGS
	    
	    RETURN
	    
	;UART COLOR CHANGE COMMAND
	EU_COLOR_CHANGE
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    BANKSEL	RCREG		    ;RETRIEVE THE RECEIVED BYTE
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	EU_RX		    ;STORE THE RECEIVED BYTE IN EU_RX
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    XORLW	0x01
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS FOR PLAYER ONE, GOTO EU_CHANGE_PLAYERONE
	    GOTO	EU_CHANGE_PLAYERONE
	    
	    MOVFW	EU_RX
	    XORLW	0x02
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS FOR PLAYER TWO, GOTO EU_CHANGE_PLAYERTWO
	    GOTO	EU_CHANGE_PLAYERTWO
	    
	    MOVFW	EU_RX
	    XORLW	0x03
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS FOR PLAYER THREE, GOTO EU_CHANGE_PLAYERTHREE
	    GOTO	EU_CHANGE_PLAYERTHREE
	    
	    MOVFW	EU_RX
	    XORLW	0x04
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS FOR PLAYER FOUR, GOTO EU_CHANGE_PLAYERFOUR
	    GOTO	EU_CHANGE_PLAYERFOUR
	    
	    GOTO	SEND_UNABLE	    ;SEND UNABLE IF THE COMMAND DOESN'T MATCH PLAYERS ONE THROUGH FOUR
	    
	;UART CHANGE PLAYER ONE COLOR COMMAND
	EU_CHANGE_PLAYERONE
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    BANKSEL	RCREG		    ;RETRIEVE THE RECEIVED BYTE
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	P1_G		    ;STORE THE RECEIVED BYTE IN P1_G
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    BANKSEL	RCREG		    ;RETRIEVE THE RECEIVED BYTE
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	P1_R		    ;STORE THE RECEIVED BYTE IN P1_R
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    BANKSEL	RCREG		    ;RETRIEVE THE RECEIVED BYTE
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	P1_B		    ;STORE THE RECEIVED BYTE IN P1_B
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    ;SAVE PLAYER ONE COLOR TO EEPROM
	    BANKSEL	PORTA		    ;SAVE P1_G TO 0X21 IN EEPROM
	    MOVLW	0x21
	    MOVWF	EEPROM_ADDR
	    MOVFW	P1_G
	    MOVWF	EEPROM_DATA
	    Call	Write_EEPROM
	    
	    BANKSEL	PORTA		    ;SAVE P1_R TO 0X20 IN EEPROM
	    MOVLW	0x20
	    MOVWF	EEPROM_ADDR
	    MOVFW	P1_R
	    MOVWF	EEPROM_DATA
	    Call	Write_EEPROM
	    
	    BANKSEL	PORTA		    ;SAVE P1_B TO 0X22 IN EEPROM
	    MOVLW	0x22
	    MOVWF	EEPROM_ADDR
	    MOVFW	P1_B
	    MOVWF	EEPROM_DATA
	    Call	Write_EEPROM
	    GOTO	SEND_UART_ACK
	    
