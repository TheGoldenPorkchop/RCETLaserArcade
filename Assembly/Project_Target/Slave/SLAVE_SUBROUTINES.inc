	;UART CALIBRATE POSITIONS COMMAND
	CHANGE_POSITIONS
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    BANKSEL	RCREG		    ;RETRIEVE THE RECEIVED BYTE
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	CAL_POS		    ;STORE THE RECEIVED BYTE IN CAL_POS
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    BANKSEL	RCREG		    ;RETRIEVE THE RECEIVED BYTE
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	CAL_PH		    ;STORE THE RECEIVED BYTE IN CAL_PH
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    BANKSEL	RCREG		    ;RETRIEVE THE RECEIVED BYTE
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	CAL_PL		    ;STORE THE RECEIVED BYTE IN CAL_PL
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    BANKSEL	PORTA
	    BTFSC	CAL_POS,7	    ;IF UPDATING SERVO1, UPDATE SERVO1
	    CALL	SAVE_SERVO1
	    
	    BTFSC	CAL_POS,6	    ;IF UPDATING SERVO2, UPDATE SERVO2
	    CALL	SAVE_SERVO2
	    
	    BTFSC	CAL_POS,5	    ;IF UPDATING SERVO3, UPDATE SERVO3
	    CALL	SAVE_SERVO3
	    
	    RETURN
	    
	;SAVE SERVO1 POSITIONS
	SAVE_SERVO1
	    BTFSS	CAL_POS,0	    ;IF UPDATING DISABLED POSITION, SKIP TO DISABLED
	    GOTO	SERVO1_DISABLED
	    MOVFW	CAL_PH		    ;GET THE HIGH BYTE
	    MOVWF	S1E_PH		    ;MOVE TO S1E_PH
	    MOVFW	CAL_PL		    ;GET THE HIGH BYTE
	    MOVWF	S1E_PL		    ;MOVE TO S1E_PL
	    ;SAVE S1 ENABLED POSITION TO EEPROM
	    BANKSEL	PORTA		    ;SAVE S1E_PH TO 0X31 IN EEPROM
	    MOVLW	0x31
	    MOVWF	EEPROM_ADDR
	    MOVFW	S1E_PH
	    MOVWF	EEPROM_DATA
	    Call	Write_EEPROM
	    BANKSEL	PORTA		    ;SAVE S1E_PL TO 0X32 IN EEPROM
	    MOVLW	0x32
	    MOVWF	EEPROM_ADDR
	    MOVFW	S1E_PL
	    MOVWF	EEPROM_DATA
	    Call	Write_EEPROM
	    RETURN	    
	SERVO1_DISABLED
	    MOVFW	CAL_PH		    ;GET THE HIGH BYTE
	    MOVWF	S1D_PH		    ;MOVE TO S1D_PH
	    MOVFW	CAL_PL		    ;GET THE HIGH BYTE
	    MOVWF	S1D_PL		    ;MOVE TO S1D_PL
	    ;SAVE S1 DISABLED POSITION TO EEPROM
	    BANKSEL	PORTA		    ;SAVE S1D_PH TO 0X3B IN EEPROM
	    MOVLW	0x33
	    MOVWF	EEPROM_ADDR
	    MOVFW	S1D_PH
	    MOVWF	EEPROM_DATA
	    Call	Write_EEPROM
