;          any player hits to the target when the target is enabled.		    *
;										    *
;************************************************************************************		
	    
SUBROUTINES_CODE CODE
    
    ;RECEIVES AND INTERPRETS I2C DATA, RESPONDS TO I2C READ REQUESTS
    RECEIVE: 
	    BANKSEL	PIR1
	    BCF		PIR1, SSP1IF		;IMMEDIATELY CLEAR INTERRUPT FLAG
	    BANKSEL	SSP1BUF			;\READ BYTE FROM MASTER
	    MOVFW	SSP1BUF			;/
	    MOVWF	RECEIVED_DATA
	    BANKSEL	SSP1STAT		;DETERMINE IF THE RECEIVED BYTE WAS DATA OR ADDRESS
	    BTFSS	SSP1STAT,5		;1=DATA, 0=ADDRESS
	    GOTO	CHECK_READ_OR_WRITE	;BYTE RECEIVED WAS ADDRESS, CHECK IF R/W
	    GOTO	SAVE_DATA		;BYTE RECEIVED WAS DATA, SAVE BYTE
	    
	CHECK_READ_OR_WRITE	
	    BTFSS	SSP1STAT,2		;TEST IF ADDRESS BYTE WAS R/W: R = 1, W = 0
	    GOTO	SAVE_DATA		;MASTER WRITE: SAVE DATA
	    GOTO	TRANSMIT_STATUS		;MASTER READ: TRANSMIT THE TARGET STATUS
	
	;TESTS THE RECEIVED DATA AGAINST THE KNOWN ENABLE AND DISABLE COMMANDS
	SAVE_DATA
	    BANKSEL	PORTA
	    MOVWF	RECEIVED_DATA
	    XORLW	0X45
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS ENABLE COMMAND, SET TARGET TO ACTIVE
	    GOTO	ENABLE_TARGET	    
	    MOVFW	RECEIVED_DATA
	    XORLW	0X44
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS DISABLE COMMAND, SET TARGET TO INACTIVE
	    GOTO	DISABLE_TARGET
	    MOVFW	RECEIVED_DATA
	    XORLW	0X43
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS DISABLE COMMAND, SET TARGET TO INACTIVE
	    GOTO	CHANGE_COLOR
	    RETURN
	    
	UART_RX
	    BANKSEL	RCREG
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	EU_RX
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    BANKSEL	PORTA
	    MOVFW	EU_RX
	    
	    XORLW	0X24
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS VB HANDSHAKE, GOTO VB RECEIVE
	    GOTO	VB_RECEIVE
	    BANKSEL	PORTA
	    MOVFW	EU_RX
	    XORLW	0X3C
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS BLASTER HANDSHAKE, GOTO BLASTER RECEIVE
	    GOTO	BLASTER_RECEIVE
	
	    RETURN
	    
	VB_RECEIVE
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	VB_RECEIVE
	    
	    
	    
	    RETURN
	    
	BLASTER_RECEIVE
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    
	    BANKSEL	RCREG
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	PLAYER_HIT
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    
	    BANKSEL	RCREG
	    MOVFW	RCREG
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    BANKSEL	PORTA
	    XORLW	0X3E
	    BTFSC	STATUS, Z	    ;IF RECEIVED BYTE IS BLASTER HANDSHAKE, GOTO HIT_RECORDED
	    GOTO	HIT_RECORDED
	    CLRF	PLAYER_HIT
	    	    
	    RETURN
	    
	HIT_RECORDED
	    CALL	DISABLE_TARGET	    ;DISABLE THE TARGET
	    
	    BANKSEL	PORTA
	    MOVFW	PLAYER_HIT
	    XORLW	0X01
	    BTFSC	STATUS, Z	    ;IF PLAYER ONE HIT THE TARGET, FLASH PLAYER ONE COLORS
	    GOTO	RECORD_PLAYER1_HIT
	    
	    MOVFW	PLAYER_HIT
	    XORLW	0X02
	    BTFSC	STATUS, Z	    ;IF PLAYER TWO HIT THE TARGET, FLASH PLAYER TWO COLORS
	    GOTO	RECORD_PLAYER2_HIT
	    
	    MOVFW	PLAYER_HIT
	    XORLW	0X03
	    BTFSC	STATUS, Z	    ;IF PLAYER THREE HIT THE TARGET, FLASH PLAYER THREE COLORS
	    GOTO	RECORD_PLAYER3_HIT
	    
	    MOVFW	PLAYER_HIT
	    XORLW	0X04
	    BTFSC	STATUS, Z	    ;IF PLAYER FOUR HIT THE TARGET, FLASH PLAYER FOUR COLORS
	    GOTO	RECORD_PLAYER4_HIT
	    
	    RETURN
	    
	ENABLE_TARGET
	    BANKSEL	PORTA
	    BSF		ACTIVE, 0
	    
	    MOVLW	0x01
	    MOVWF	_LEDNUMBER
	    MOVLW	0xFF
	    MOVWF	_SENDLEDGREEN
	    MOVLW	0x00
	    MOVWF	_SENDLEDBLUE
	    MOVLW	0x00
	    MOVWF	_SENDLEDRED
	    
	    CALL	SENDLED
	    	
	    RETURN
	    
	DISABLE_TARGET
	    BANKSEL	PORTA
	    BCF		ACTIVE, 0
	    
	    MOVLW	0x01
	    MOVWF	_LEDNUMBER
	    MOVLW	0x00
	    MOVWF	_SENDLEDGREEN
	    MOVLW	0x00
	    MOVWF	_SENDLEDBLUE
	    MOVLW	0x00
	    MOVWF	_SENDLEDRED
	    
	    CALL	SENDLED
	    	
	    RETURN
	    
	CHANGE_COLOR
	
	    RETURN
    
	;TRANSMIT THE CURRENT TARGET STATUS BACK TO THE MASTER IF A READ WAS RECEIVED
	TRANSMIT_STATUS
	    BANKSEL	PORTA
	    MOVFW	PLAYER_HIT	    ;RETREIVE THE CURRENT TARGET STATUS
	    BANKSEL	SSP1BUF
	    MOVWF	SSP1BUF		    ;MOVE THE TARGET STATUS INTO THE I2C BUFFER
	    BANKSEL	SSP1CON1
	    BSF		SSP1CON1, CKP	    ;START THE CLOCK TO BEGIN DATA TRANSMISSION
	    BANKSEL	PORTA
	    CLRF	PLAYER_HIT
	    RETURN
	    
