	;UART UPDATE LED NUMBER COMMAND
	UPDATE_LED_NUMBER
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    BANKSEL	RCREG		    ;RETRIEVE THE RECEIVED BYTE
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	_LEDNUMBER	    ;STORE THE RECEIVED BYTE IN _LEDNUMBER
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    ;SAVE _LEDNUMBER TO EEPROM
	    BANKSEL	PORTA		    ;SAVE _LEDNUMBER TO 0X14 IN EEPROM
	    MOVLW	0x14
	    MOVWF	EEPROM_ADDR
	    MOVFW	_LEDNUMBER
	    MOVWF	EEPROM_DATA
	    Call	Write_EEPROM
	    
	    GOTO	SEND_UART_ACK
	    
	;UART UPDATE I2C ADDRESS COMMAND
	UPDATE_ADDRESS
	    BANKSEL	PIR1		    ;WAIT TO RECEIVE AGAIN
	    BTFSS	PIR1, RCIF
	    GOTO	$-1
	    BANKSEL	RCREG		    ;RETRIEVE THE RECEIVED BYTE
	    MOVFW	RCREG
	    BANKSEL	PORTA
	    MOVWF	EU_RX
	    BANKSEL	PIR1		    ;CLEAR THE INTERRUPT FLAG
	    BCF		PIR1, RCIF
	    
	    BANKSEL	SSPADD		
	    MOVWF	SSPADD		    ;SET I2C ADDRESS
	    
	    ;SAVE I2C ADDRESS TO EEPROM
	    BANKSEL	PORTA
	    MOVLW	0x10
	    MOVWF	EEPROM_ADDR
	    BANKSEL	SSPADD
	    MOVFW	SSPADD
	    BANKSEL	PORTA
	    MOVWF	EEPROM_DATA
	    Call	Write_EEPROM
	    GOTO	SEND_UART_ACK
	    
	;SEND ACKNOWLEDGE
	SEND_UART_ACK
	    BANKSEL	    TXSTA
	    BTFSS	    TXSTA, TRMT	    ;WAIT FOR TX TO BE AVAILABLE
	    GOTO	    $-1
	    BANKSEL	    TX1REG
	    MOVLW	    0x24	    ;SENDS THE DOLLAR HANDSHAKE
	    MOVWF	    TX1REG
	    
	    BANKSEL	    TXSTA
	    BTFSS	    TXSTA, TRMT	    ;WAIT FOR TX TO BE AVAILABLE
	    GOTO	    $-1
	    BANKSEL	    TX1REG
	    MOVLW	    0x41	    ;SENDS THE A
	    MOVWF	    TX1REG
	    RETURN
	    
